# ─── 必填 ───
# AI API 配置
AI_BASE_URL=https://yunwu.ai/v1/chat/completions
AI_API_KEY_CHEAP=sk-xxx
AI_API_KEY_PREMIUM=sk-xxx
AI_MODEL=gemini-3.1-flash-lite-preview
AI_MODEL_BACKUP=gpt-4o-mini

# Jina API（素材采集）
JINA_API_KEY=jina_xxx

# Web 访问密钥
ACCESS_KEY=your-secret-key-here

# ─── 可选 ───
# 邮件配置
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SENDER=writer@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_RECEIVER=team@example.com

# AI 参数（一般不需要改）
AI_TEMPERATURE=0.2
AI_TOP_P=0.95
AI_TIMEOUT=60
